# ═══════════════════════════════════════════════════════════════
# Consultation form configuration (Web3Forms)
#
# 1. Copy this file to .env.local
#    (Windows PowerShell:  copy .env.local.example .env.local )
# 2. Restart `npm run dev` after any change.
# ═══════════════════════════════════════════════════════════════

# Web3Forms access key — obtain from https://web3forms.com
# The owner of this key receives every form submission in their inbox.
WEB3FORMS_ACCESS_KEY=defec4c5-721e-4561-b8cf-f8a275d7f3a1

# ─────────────────────────────────────────────────────────────
# Optional: client confirmation email ("Autoresponder")
#
# Web3Forms can automatically send the submitter a confirmation
# after every form submission. Enable it inside your Web3Forms
# dashboard — there is no extra env variable required:
#
#   1. Log in at https://web3forms.com
#   2. Open your form settings
#   3. Enable "Autoresponder"
#   4. Set the subject line and HTML/plain body
#      e.g.  Subject:  "Thanks — we received your consultation request"
#            Body:     "Hi {{name}}, thanks for reaching out. A Quad
#                       Healthcare specialist will contact you within
#                       one business day..."
#   5. Save. Next submission will trigger the auto-reply.
# ─────────────────────────────────────────────────────────────
